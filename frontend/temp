  <script>
    let tasks = [];
    let isListening = false;
    let confirmCallback = null;
    const micBtn = document.getElementById('mic-btn');
    const voicePanel = document.getElementById('voice-panel');
    const shell = document.getElementById('transcript-shell');
    const chatMessages = document.getElementById('chat-messages');
    const aiStatus = document.getElementById('ai-status');
    const aiStatusText = document.getElementById('ai-status-text');
    const waveIndicator = document.getElementById('wave-indicator');
    const taskGrid = document.getElementById('task-grid');
    const emptyState = document.getElementById('empty-state');
    const confirmOverlay = document.getElementById('confirm-overlay');
    const confirmCard = document.getElementById('confirm-card');

    const statusSequence = ['Listening...', 'Thinking...', 'Speaking...'];
    let statusIndex = 0;
    let statusInterval = null;

    const dataHandler = {
      onDataChanged(data) {
        tasks = [...data].sort((a, b) => (a.created_at || '').localeCompare(b.created_at || ''));
        renderTasks();
      }
    };

    function getTimeLabel(createdDate) {
      if (!createdDate) return 'No date';
      const now = new Date();
      const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      const taskDay = new Date(createdDate.getFullYear(), createdDate.getMonth(), createdDate.getDate());
      const diffTime = taskDay - today;
      const diffDays = Math.round(diffTime / (1000 * 60 * 60 * 24));
      
      if (diffDays === 0) return 'Today';
      else if (diffDays === 1) return 'Tomorrow';
      else if (diffDays > 1 && diffDays <= 30) return `In ${diffDays}d`;
      else return createdDate.toLocaleDateString('en', { month: 'short', day: 'numeric' });
    }

    function renderTasks() {
      const existing = new Map([...taskGrid.children].map(el => [el.dataset.id, el]));
      const ids = new Set(tasks.map(t => t.__backendId));
      
      existing.forEach((el, id) => { 
        if (!ids.has(id)) { 
          el.classList.add('card-deleting'); 
          setTimeout(() => el.remove(), 400); 
        } 
      });
      
      tasks.forEach((task, i) => {
        const el = taskGrid.querySelector(`[data-id="${task.__backendId}"]`);
        if (el) { 
          updateCard(el, task); 
          // Reorder animation
          const rect = el.getBoundingClientRect();
          const newIndex = Array.from(taskGrid.children).indexOf(el);
          el.style.gridColumn = `auto`;
          el.style.gridRow = `auto`;
        } else {
          const card = createCard(task);
          card.style.animationDelay = `${i * 0.05}s`;
          taskGrid.appendChild(card);
        }
      });
      emptyState.classList.toggle('hidden', tasks.length > 0);
    }

    function createCard(task) {
      const frag = document.getElementById('task-card-template').content.cloneNode(true);
      const card = frag.querySelector('[data-template-id="task-card"]');
      card.dataset.id = task.__backendId;
      updateCard(card, task);
      return card;
    }

    function updateCard(card, task) {
      card.querySelector('[data-template-id="task-card-name"]').textContent = task.name || 'Untitled';
      card.querySelector('[data-template-id="task-card-details"]').textContent = task.details || '';
      
      const s = card.querySelector('[data-template-id="task-card-status"]');
      const dot = card.querySelector('#card-status-dot');
      const done = task.status === 'completed';
      s.textContent = done ? 'Done' : 'Pending';
      dot.className = `status-dot ${done ? 'status-completed' : 'status-pending'}`;

      const timeValue = card.querySelector('#card-time-value');
      const timeLabel = card.querySelector('#card-time-label');
      const taskTime = task.time || '';
      const createdDate = task.created_at ? new Date(task.created_at) : null;
      
      timeValue.textContent = taskTime;
      timeLabel.textContent = getTimeLabel(createdDate);
    }

    function showConfirmCard(title, desc, action, glow = 'delete-glow') {
      confirmOverlay.classList.remove('hidden');
      confirmCard.classList.remove('hidden');
      confirmCard.className = `confirm-card ${glow}`;
      document.getElementById('confirm-title').textContent = title;
      document.getElementById('confirm-desc').textContent = desc;
      confirmCallback = action;
    }

    function hideConfirmCard() {
      confirmOverlay.classList.add('hidden');
      confirmCard.classList.add('hidden');
      confirmCallback = null;
    }

    document.getElementById('confirm-cancel').addEventListener('click', hideConfirmCard);
    document.getElementById('confirm-action').addEventListener('click', () => {
      if (confirmCallback) confirmCallback();
      hideConfirmCard();
    });
    confirmOverlay.addEventListener('click', hideConfirmCard);

    micBtn.addEventListener('click', () => {
      isListening = !isListening;
      micBtn.classList.toggle('active', isListening);
      voicePanel.classList.toggle('active', isListening);
      shell.classList.toggle('open', isListening);
      showWave(isListening);
      if (isListening) {
        statusIndex = 0;
        chatMessages.innerHTML = '';
        aiStatusText.textContent = statusSequence[0];
        aiStatus.style.display = 'flex';
        statusInterval = setInterval(() => {
          statusIndex = (statusIndex + 1) % statusSequence.length;
          aiStatusText.textContent = statusSequence[statusIndex];
        }, 1500);
        setTimeout(() => {
          addMessage('user', 'Schedule a meeting with the team tomorrow at 10 AM');
          addMessage('ai', "Creating task for you...");
          setTimeout(() => {
            showConfirmCard('Add Task?', 'Schedule meeting with team tomorrow at 10 AM', 
              () => addMessage('ai', 'Task added! Meeting scheduled for tomorrow.'), 'update-glow');
          }, 2500);
        }, 3000);
      } else {
        if (statusInterval) clearInterval(statusInterval);
        aiStatus.style.display = 'none';
        hideConfirmCard();
      }
    });

    document.getElementById('end-btn').addEventListener('click', () => {
      isListening = false; 
      micBtn.classList.remove('active'); 
      voicePanel.classList.remove('active');
      shell.classList.remove('open'); 
      showWave(false);
      if (statusInterval) clearInterval(statusInterval);
      aiStatus.style.display = 'none';
      hideConfirmCard();
    });

    function showWave(v) { waveIndicator.classList.toggle('hidden', !v); }

    function addMessage(role, text) {
      const div = document.createElement('div');
      div.className = `chat-msg flex ${role === 'user' ? 'justify-end' : 'justify-start'}`;
      div.innerHTML = `<div class="max-w-[80%] px-3 py-2 rounded-2xl text-[13px] leading-relaxed ${role === 'user' ? 'bg-white/10 text-white' : 'bg-white/[0.03] text-white/40'}">${text}</div>`;
      chatMessages.appendChild(div);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    (async () => {
      const r = await window.dataSdk.init(dataHandler);
      if (!r.isOk) { emptyState.textContent = 'Failed to load tasks.'; emptyState.classList.remove('hidden'); }
      const dummyTasks = [
        { name: 'Design system audit', details: 'Review spacing, typography and component consistency', time: '2:30 PM', status: 'completed', created_at: new Date(Date.now() - 86400000).toISOString(), __backendId: 'dummy-1' },
        { name: 'Ship onboarding flow', details: 'Finalize the 3-step signup experience', time: '3:15 PM', status: 'pending', created_at: new Date(Date.now() - 72000000).toISOString(), __backendId: 'dummy-2' },
        { name: 'API documentation', details: 'Write endpoint specs for v2 release', time: '4:45 PM', status: 'pending', created_at: new Date(Date.now() - 57600000).toISOString(), __backendId: 'dummy-3' },
        { name: 'Stakeholder sync', details: 'Present Q3 roadmap priorities', time: '5:30 PM', status: 'pending', created_at: new Date(Date.now() - 43200000).toISOString(), __backendId: 'dummy-4' },
        { name: 'Production deploy', details: 'Release v2.1 with performance fixes', time: '6:00 PM', status: 'completed', created_at: new Date(Date.now() - 28800000).toISOString(), __backendId: 'dummy-5' }
      ];
      dataHandler.onDataChanged(dummyTasks);

      // DEMO: Delete animation after 5s
      setTimeout(() => {
        const deleteCard = taskGrid.querySelector('[data-id="dummy-5"]');
        if (deleteCard) {
          deleteCard.classList.add('card-delete-glow');
          showConfirmCard('Delete Task?', 'Production deploy - Release v2.1 with performance fixes', () => {
            deleteCard.classList.add('card-deleting');
            setTimeout(() => deleteCard.remove(), 400);
            addMessage('ai', 'Task deleted successfully.');
          }, 'delete-glow');
        }
      }, 5000);

      // DEMO: Update animation after 10s
      setTimeout(() => {
        const updateCard = taskGrid.querySelector('[data-id="dummy-2"]');
        if (updateCard) {
          updateCard.classList.add('card-update-glow');
          showConfirmCard('Update Task?', 'Mark Ship onboarding flow as completed?', () => {
            const statusSpan = updateCard.querySelector('[data-template-id="task-card-status"]');
            const statusDot = updateCard.querySelector('#card-status-dot');
            statusSpan.textContent = 'Done';
            statusDot.className = 'status-dot status-completed';
            addMessage('ai', 'Task marked as completed!');
          }, 'update-glow');
        }
      }, 10000);

      // DEMO: Add new card animation after 15s
      setTimeout(() => {
        const newTask = {
          name: 'Team retrospective',
          details: 'Discuss sprint wins and improvements',
          time: '7:00 PM',
          status: 'pending',
          created_at: new Date().toISOString(),
          __backendId: 'dummy-6-' + Date.now()
        };
        showConfirmCard('Add Task?', 'Create new task: Team retrospective - Discuss sprint wins and improvements', () => {
          tasks.push(newTask);
          renderTasks();
          addMessage('ai', 'New task created: Team retrospective');
        }, 'update-glow');
      }, 15000);

      lucide.createIcons();
    })();
  </script>

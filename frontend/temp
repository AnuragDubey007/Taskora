<html lang="en">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Voice Task Manager</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <style>
    * { font-family: 'Outfit', sans-serif; }
    .page-bg { min-height: calc(100 * min(var(--vh, 1vh), 1vh)); background: #000; }

    .hero-heading {
      color: #ffffff;
      background: linear-gradient(135deg, #ffffff 0%, #d8d8d8 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }

    .hero-glow {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      width: 500px; height: 500px; border-radius: 50%;
      background: radial-gradient(circle, rgba(255,255,255,0.04) 0%, transparent 70%);
      pointer-events: none;
    }

    @keyframes fade-up { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
    @keyframes fade-in { from { opacity:0; } to { opacity:1; } }
    .anim-1 { animation: fade-up 0.7s ease both; }
    .anim-2 { animation: fade-up 0.7s ease 0.1s both; }
    .anim-3 { animation: fade-up 0.7s ease 0.2s both; }
    .anim-4 { animation: fade-up 0.7s ease 0.35s both; }

    .task-card {
      background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.04) 100%);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 16px;
      padding: 20px;
      backdrop-filter: blur(20px);
      transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      animation: fade-up 0.5s ease both;
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .task-card::before {
      content: '';
      position: absolute;
      top: -85%;
      left: 50%;
      transform: translateX(-50%);
      width: 320px;
      height: 320px;
      background: radial-gradient(circle, rgba(255,255,255,0.28) 0%, rgba(255,255,255,0.12) 25%, rgba(255,255,255,0.04) 50%, transparent 70%);
      border-radius: 50%;
      opacity: 0;
      transition: opacity 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      pointer-events: none;
    }
    .task-card:hover {
      border-color: rgba(255,255,255,0.2);
      transform: translateY(-6px);
      box-shadow: 0 24px 72px rgba(255,255,255,0.15);
      background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.06) 100%);
    }
    .task-card:hover::before {
      opacity: 1;
    }
    .card-deleting { animation: card-out 0.35s ease forwards; }
    @keyframes card-out { to { opacity:0; transform:scale(0.9); height:0; padding:0; margin:0; overflow:hidden; } }
    


    .voice-panel { position:fixed; bottom:24px; left:50%; transform:translateX(-50%); z-index:50; display:flex; flex-direction:column; align-items:center; }
    
    .mic-glow-backdrop {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 120px; height: 120px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.04) 35%, transparent 70%);
      opacity: 0;
      transition: opacity 0.4s ease;
      pointer-events: none;
      z-index: 1;
    }
    
    .mic-btn {
      width:56px; height:56px; border-radius:50%;
      background: radial-gradient(circle at 32% 32%, #ffffff 0%, #f8f8f8 12%, #f0f0f0 28%, #e6e6e6 50%, #d8d8d8 75%, #ccc 100%);
      box-shadow: 0 12px 48px rgba(255,255,255,0.3), 0 0 0 1px rgba(255,255,255,0.4), inset 0 3px 6px rgba(255,255,255,0.8), inset 0 -4px 10px rgba(0,0,0,0.15);
      transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s cubic-bezier(0.34,1.56,0.64,1), background 0.3s ease;
      position: relative;
      overflow: visible;
      z-index: 100;
    }
    .mic-btn::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      width: 56px; height: 56px;
      border-radius: 50%;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0.05) 50%, transparent 70%);
      opacity: 0;
      transition: opacity 0.3s ease;
      pointer-events: none;
      z-index: 2;
    }
    .mic-btn:hover {
      transform: scale(1.15);
      background: radial-gradient(circle at 32% 32%, #ffffff 0%, #fafafa 12%, #f2f2f2 28%, #e8e8e8 50%, #dcdcdc 75%, #d0d0d0 100%);
      box-shadow: 0 18px 64px rgba(255,255,255,0.42), 0 0 0 2px rgba(255,255,255,0.5), inset 0 3px 7px rgba(255,255,255,0.9), inset 0 -4px 10px rgba(0,0,0,0.1);
    }
    .mic-btn.active {
      background: radial-gradient(circle at 32% 32%, #ffffff 0%, #f8f8f8 12%, #f0f0f0 28%, #e6e6e6 50%, #d8d8d8 75%, #ccc 100%);
      box-shadow: 0 12px 48px rgba(255,255,255,0.3), 0 0 0 1px rgba(255,255,255,0.4), inset 0 3px 6px rgba(255,255,255,0.8), inset 0 -4px 10px rgba(0,0,0,0.15);
      animation: heartbeat-glow 1.2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    .mic-btn.active::before {
      opacity: 1;
      animation: glow-pulse-ring 1.8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    .mic-btn.active::after {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      width: 56px; height: 56px;
      border: 2px solid rgba(255,255,255,0.5);
      border-radius: 50%;
      transform: translate(-50%, -50%);
      animation: pulse-ring-outer 1.8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
      pointer-events: none;
      z-index: 3;
    }
    
    .voice-panel.active .mic-glow-backdrop {
      opacity: 1;
      animation: backdrop-pulse 2.4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    
    .voice-panel.active .mic-glow-backdrop::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      width: 100%; height: 100%;
      border-radius: 50%;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 40%, transparent 70%);
      animation: backdrop-ring-pulse 2.8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
      pointer-events: none;
    }
    
    .voice-panel.active .mic-glow-backdrop::after {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      width: 160px; height: 160px;
      border-radius: 50%;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle, rgba(255,255,255,0.04) 0%, transparent 65%);
      animation: backdrop-ring-pulse-outer 3.2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
      pointer-events: none;
    }
    
    @keyframes glow-breathing {
      0%, 100% { box-shadow: 0 12px 48px rgba(255,255,255,0.25), 0 0 0 1px rgba(255,255,255,0.35), inset 0 3px 6px rgba(255,255,255,0.75), inset 0 -4px 10px rgba(0,0,0,0.15); }
      50% { box-shadow: 0 18px 68px rgba(255,255,255,0.45), 0 0 0 2px rgba(255,255,255,0.5), inset 0 3px 8px rgba(255,255,255,0.9), inset 0 -4px 10px rgba(0,0,0,0.1); }
    }
    @keyframes heartbeat-glow {
      0%, 100% { box-shadow: 0 12px 48px rgba(255,255,255,0.2), 0 0 0 1px rgba(255,255,255,0.35), inset 0 3px 6px rgba(255,255,255,0.75), inset 0 -4px 10px rgba(0,0,0,0.15); }
      10% { box-shadow: 0 18px 64px rgba(255,255,255,0.4), 0 0 0 1px rgba(255,255,255,0.45), inset 0 3px 7px rgba(255,255,255,0.85), inset 0 -4px 10px rgba(0,0,0,0.1); }
      15% { box-shadow: 0 12px 48px rgba(255,255,255,0.2), 0 0 0 1px rgba(255,255,255,0.35), inset 0 3px 6px rgba(255,255,255,0.75), inset 0 -4px 10px rgba(0,0,0,0.15); }
      25% { box-shadow: 0 18px 64px rgba(255,255,255,0.4), 0 0 0 1px rgba(255,255,255,0.45), inset 0 3px 7px rgba(255,255,255,0.85), inset 0 -4px 10px rgba(0,0,0,0.1); }
      35% { box-shadow: 0 12px 48px rgba(255,255,255,0.2), 0 0 0 1px rgba(255,255,255,0.35), inset 0 3px 6px rgba(255,255,255,0.75), inset 0 -4px 10px rgba(0,0,0,0.15); }
    }
    @keyframes glow-pulse-ring {
      0% { width: 56px; height: 56px; opacity: 0.8; background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 70%); }
      50% { width: 92px; height: 92px; opacity: 0.3; background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0) 70%); }
      100% { width: 56px; height: 56px; opacity: 0.8; background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 70%); }
    }
    @keyframes pulse-ring-outer {
      0% { width: 56px; height: 56px; border-color: rgba(255,255,255,0.6); opacity: 1; }
      100% { width: 120px; height: 120px; border-color: rgba(255,255,255,0); opacity: 0; }
    }
    @keyframes backdrop-pulse {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
      50% { transform: translate(-50%, -50%) scale(1.15); opacity: 1; }
    }
    @keyframes backdrop-ring-pulse {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.4; }
      50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.8; }
    }
    @keyframes backdrop-ring-pulse-outer {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.2; }
      50% { transform: translate(-50%, -50%) scale(1.25); opacity: 0.5; }
    }

    .transcript-shell {
      position:absolute; bottom:72px; left:50%; transform:translateX(-50%);
      width:0; max-height:0; opacity:0;
      background: rgba(10,10,10,0.97); backdrop-filter:blur(24px);
      border:1px solid rgba(255,255,255,0.08); border-radius:20px;
      overflow:hidden; pointer-events:none;
      transition: width 0.4s cubic-bezier(0.34,1.56,0.64,1), max-height 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.3s ease;
    }
    .transcript-shell.open { width:min(480px,88vw); max-height:240px; opacity:1; pointer-events:auto; }
    .transcript-inner { opacity:0; transition:opacity 0.3s ease 0.25s; height:240px; display:flex; flex-direction:column; }
    .transcript-shell.open .transcript-inner { opacity:1; }

    .wave-line { display:flex; align-items:center; gap:2px; height:24px; }
    .wave-line span { width:3px; border-radius:2px; background:linear-gradient(to top, #ffffff, #f0f0f0); box-shadow:0 0 8px rgba(255,255,255,0.4), inset 0 1px 2px rgba(255,255,255,0.6); animation:glow-pulse 1.2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    .wave-line span:nth-child(1){animation-delay:0s;} .wave-line span:nth-child(2){animation-delay:0.15s;} .wave-line span:nth-child(3){animation-delay:0.3s;} .wave-line span:nth-child(4){animation-delay:0.15s;} .wave-line span:nth-child(5){animation-delay:0s;}
    @keyframes glow-pulse { 0%{height:4px;opacity:0.3;box-shadow:0 0 6px rgba(255,255,255,0.2), inset 0 1px 2px rgba(255,255,255,0.4);} 50%{height:20px;opacity:1;box-shadow:0 0 16px rgba(255,255,255,0.7), inset 0 1px 3px rgba(255,255,255,0.8);} 100%{height:4px;opacity:0.3;box-shadow:0 0 6px rgba(255,255,255,0.2), inset 0 1px 2px rgba(255,255,255,0.4);} }

    .chat-msg { animation: msg-in 0.2s ease; }
    @keyframes msg-in { from{opacity:0;transform:translateY(4px);} }
    ::-webkit-scrollbar{width:3px;} ::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:3px;}

    #confirm-overlay { z-index: 199; }
    .status-dot { width:8px; height:8px; border-radius:50%; }
    .status-pending { background:#555; }

    .ai-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.4); margin: 0 2px; animation: dot-pulse 1.2s ease-in-out infinite; }
    .ai-dot:nth-child(1) { animation-delay: 0s; }
    .ai-dot:nth-child(2) { animation-delay: 0.2s; }
    .ai-dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes dot-pulse { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }

    .feature-badge { display: inline-flex; align-items: center; gap: 4px; padding: 6px 12px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; font-size: 11px; font-weight: 600; color: #ffffff; }

    .confirm-card { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 200; background: rgba(10,10,10,0.98); backdrop-filter: blur(30px); border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; padding: 32px; max-width: 360px; box-shadow: 0 0 60px rgba(255,255,255,0.1); animation: confirm-pop 0.3s cubic-bezier(0.34,1.56,0.64,1); }
    @keyframes confirm-pop { from { opacity: 0; transform: translate(-50%, -50%) scale(0.9); } to { opacity: 1; transform: translate(-50%, -50%) scale(1); } }
    
    .confirm-card.delete-glow { border-color: rgba(239,68,68,0.5); box-shadow: 0 0 60px rgba(239,68,68,0.3), inset 0 0 30px rgba(239,68,68,0.1); }
    .confirm-card.update-glow { border-color: rgba(34,197,94,0.5); box-shadow: 0 0 60px rgba(34,197,94,0.3), inset 0 0 30px rgba(34,197,94,0.1); }

    .card-reorder { transition: all 0.35s cubic-bezier(0.34,1.56,0.64,1); }
    .card-update-glow { animation: update-pulse 0.6s ease-out; }
    @keyframes update-pulse { 0% { box-shadow: 0 0 30px rgba(34,197,94,0.6), inset 0 0 20px rgba(34,197,94,0.2); } 100% { box-shadow: 0 0 0px rgba(34,197,94,0), inset 0 0 0px rgba(34,197,94,0); } }
    
    .card-delete-glow { animation: delete-pulse 0.6s ease-out; }
    @keyframes delete-pulse { 0% { box-shadow: 0 0 30px rgba(239,68,68,0.6), inset 0 0 20px rgba(239,68,68,0.2); } 100% { box-shadow: 0 0 0px rgba(239,68,68,0), inset 0 0 0px rgba(239,68,68,0); } }

    .card-header { display: grid; grid-template-columns: 1fr auto; align-items: flex-start; gap: 16px; width: 100%; }
    .status-badge { display: flex; align-items: center; gap: 6px; flex-shrink: 0; margin-top: auto; }
    
    .card-time-section { display: flex; align-items: center; gap: 10px; flex-shrink: 0; padding: 8px 12px; background: rgba(255,255,255,0.06); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); }
    .time-icon { width: 16px; height: 16px; color: rgba(255,255,255,0.6); flex-shrink: 0; }
    .time-display { display: flex; flex-direction: column; gap: 2px; align-items: flex-start; }
    .time-value { font-size: 13px; font-weight: 600; color: #ffffff; line-height: 1.2; }
    .time-label { font-size: 10px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.06em; font-weight: 500; }
  </style>
  <script src="/_sdk/resizing_sdk.js" type="text/javascript"></script>
